<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_multicompany_transfer" model="ir.module.category">
        <field name="name">Multi-Company Stock Transfer</field>
        <field name="sequence">100</field>
    </record>

    <record id="group_multicompany_transfer_user" model="res.groups">
        <field name="name">Multi-Company Stock Transfer User</field>
        <field name="category_id" ref="module_category_multicompany_transfer"/>
        <field name="comment">Can read allowed transfer records, create transfer requests, edit draft transfers, and open related pickings.</field>
    </record>

    <record id="group_multicompany_transfer_manager" model="res.groups">
        <field name="name">Multi-Company Stock Transfer Manager</field>
        <field name="category_id" ref="module_category_multicompany_transfer"/>
        <field name="implied_ids" eval="[(4, ref('group_multicompany_transfer_user'))]"/>
        <field name="comment">Can confirm transfers, cancel eligible transfers, configure transfer routes, and view transfer records for allowed companies.</field>
    </record>

    <!-- Record Rule: Multi-Company Transfer Access -->
    <record id="rule_multicompany_transfer_access" model="ir.rule">
        <field name="name">Multi-Company Transfer Access</field>
        <field name="model_id" ref="model_kio_multicompany_stock_transfer"/>
        <field name="domain_force">['|', ('source_company_id', 'in', company_ids), ('destination_company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('group_multicompany_transfer_user'))]"/>
    </record>
</odoo>
